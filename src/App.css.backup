/* ===== BASE STYLES ===== */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.app {
  min-height: 100vh;
  background-color: #0a0a0a;
  color: #ffffff;
  font-family: var(--font-main);
}

.pageLoadingState {
  min-height: 40vh;
  display: grid;
  place-items: center;
  color: rgba(255, 255, 255, 0.72);
  font-size: 14px;
  letter-spacing: 0.03em;
}

/* ===== INTRO OVERLAY ===== */
.threeIntroOverlay {
  --intro-shift-x: 0px;
  --intro-shift-y: 0px;
  --intro-scale: 1;
  position: fixed;
  inset: 0;
  z-index: 5000;
  display: grid;
  place-items: center;
  overflow: hidden;
  isolation: isolate;
  opacity: 1;
  transition: opacity 0.5s ease 0.72s;
}

.threeIntroOverlay::before,
.threeIntroOverlay::after {
  content: "";
  position: absolute;
  inset: 0;
  transition: opacity 1.05s cubic-bezier(0.22, 0.8, 0.25, 1);
}

.threeIntroOverlay::before {
  background:
    radial-gradient(circle at 50% 32%, rgba(37, 78, 54, 0.08), transparent 24%),
    linear-gradient(180deg, #f8f7f3 0%, #f0eee7 100%);
  opacity: 1;
  z-index: -2;
}

.threeIntroOverlay::after {
  background:
    radial-gradient(circle at 50% 20%, rgba(255, 215, 140, 0.08), transparent 24%),
    linear-gradient(180deg, rgba(16, 18, 17, 0.92) 0%, rgba(10, 10, 10, 0.98) 100%);
  opacity: 0;
  z-index: -1;
}

.threeIntroOverlay.leaving {
  opacity: 0;
  pointer-events: none;
}

.threeIntroOverlay.leaving::before {
  opacity: 0;
}

.threeIntroOverlay.leaving::after {
  opacity: 1;
}

.threeIntroStage {
  width: min(520px, calc(100vw - 40px));
  position: relative;
  z-index: 1;
  display: grid;
  justify-items: center;
  gap: 28px;
}

.threeIntroBadge {
  font-family: 'Space Grotesk', system-ui, sans-serif;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.26em;
  color: rgba(27, 73, 46, 0.7);
  margin-bottom: 10px;
}

.threeIntroOrbital {
  position: relative;
  width: clamp(168px, 28vw, 220px);
  aspect-ratio: 1;
  display: grid;
  place-items: center;
  will-change: transform, opacity;
  filter: drop-shadow(0 24px 42px rgba(32, 48, 38, 0.1));
  transition:
    transform 1.08s cubic-bezier(0.2, 0.86, 0.22, 1),
    opacity 0.4s ease,
    filter 1.08s cubic-bezier(0.2, 0.86, 0.22, 1);
}

.threeIntroOverlay.leaving .threeIntroOrbital {
  transform: translate(var(--intro-shift-x), var(--intro-shift-y)) scale(var(--intro-scale));
  filter: drop-shadow(0 10px 18px rgba(0, 0, 0, 0.14));
}

.threeIntroOrbitBase,
.threeIntroOrbitSpinner {
  position: absolute;
  inset: 0;
  border-radius: 50%;
}

.threeIntroOrbitBase {
  border: 1px solid rgba(9, 15, 12, 0.18);
  box-shadow: 0 0 0 10px rgba(255, 255, 255, 0.45);
}

.threeIntroOrbitSpinner {
  inset: -6px;
  border: 2px solid transparent;
  border-top-color: #214d34;
  border-right-color: rgba(33, 77, 52, 0.45);
  animation: threeIntroSpin 1s linear infinite;
  will-change: transform;
}

.threeIntroLogoCore {
  width: 72%;
  aspect-ratio: 1;
  border-radius: 50%;
  display: grid;
  place-items: center;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 12px 34px rgba(33, 47, 38, 0.12);
}

.threeIntroLogoMark {
  width: 88%;
  height: 88%;
  object-fit: contain;
  filter: saturate(0.72) contrast(1.06);
}

.threeIntroLogoFallback {
  color: #214d34;
  font-size: 26px;
  font-weight: 700;
  letter-spacing: 0.12em;
}

.threeIntroWordmark {
  text-align: center;
  animation: threeIntroRise 700ms cubic-bezier(0.22, 0.8, 0.25, 1) both;
  transition: opacity 0.45s ease, transform 0.65s cubic-bezier(0.22, 0.8, 0.25, 1), filter 0.65s ease;
}

.threeIntroOverlay.leaving .threeIntroWordmark {
  opacity: 0;
  transform: translateY(18px);
  filter: blur(4px);
}

.threeIntroWordmark h1 {
  font-family: var(--font-heading);
  font-size: clamp(34px, 8vw, 58px);
  line-height: 1;
  letter-spacing: 0.24em;
  text-indent: 0.24em;
  font-weight: 700;
  color: #18452e;
}

.threeIntroWordmark p:last-child {
  font-family: var(--font-main);
  margin-top: 12px;
  color: rgba(24, 69, 46, 0.66);
  font-size: 18px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.threeIntroSkipBtn {
  position: absolute;
  right: 20px;
  bottom: 20px;
  z-index: 1;
  border-radius: 999px;
  border: 1px solid rgba(24, 69, 46, 0.18);
  background: rgba(255, 255, 255, 0.65);
  color: #18452e;
  padding: 8px 14px;
  font-size: 12px;
  font-weight: 600;
  backdrop-filter: blur(8px);
  transition: opacity 0.28s ease, transform 0.28s ease, background 0.2s ease;
}

.threeIntroOverlay.leaving .threeIntroSkipBtn {
  opacity: 0;
  transform: translateY(12px);
}

.threeIntroSkipBtn:hover {
  background: rgba(255, 255, 255, 0.88);
}

@keyframes threeIntroSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes threeIntroRise {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Performance optimization */
.listings,
.experiences,
.footer {
  content-visibility: auto;
  contain-intrinsic-size: 900px;
}

#hero,
#listings,
#stats,
#experiences,
#footer {
  scroll-margin-top: 116px;
}

/* ===== NAVBAR ===== */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22px 48px;
  background: linear-gradient(to bottom, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 50%, transparent 100%);
}

.logo {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  width: 240px;
  height: 64px;
  overflow: visible;
}

.logoImg {
  height: 64px;
  width: auto;
  object-fit: contain;
  transform: scale(2.0);
  transform-origin: left center;
  filter: brightness(0) invert(1);
}

.navLinks {
  display: flex;
  gap: 32px;
}

.navLink {
  color: rgba(255,255,255,0.9);
  text-decoration: none;
  font-size: 14px;
  font-weight: 500;
  transition: color 0.2s ease;
}

.navLink:hover {
  color: #f5a623;
}

.navActions {
  display: flex;
  align-items: center;
  gap: 16px;
}

.authButtons {
  display: flex;
  align-items: center;
  gap: 10px;
}

.authBtn {
  border: 1px solid transparent;
  border-radius: 24px;
  padding: 9px 16px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
}

.authBtnSecondary {
  background: transparent;
  border-color: rgba(255,255,255,0.35);
  color: rgba(255,255,255,0.92);
}

.authBtnSecondary:hover {
  border-color: rgba(255,255,255,0.65);
  background: rgba(255,255,255,0.08);
}

.authBtnPrimary {
  background-color: #ffffff;
  color: #101010;
  border-color: rgba(255,255,255,0.95);
}

.authBtnPrimary:hover {
  background-color: rgba(255,255,255,0.86);
  border-color: #ffffff;
  transform: translateY(-1px);
}

.userMenuContainer {
  position: relative;
}

.avatarButton {
  background: transparent;
  border: none;
  padding: 0;
  cursor: pointer;
}

.bookBtn {
  background-color: #f5a623;
  color: #000000;
  border: none;
  padding: 10px 20px;
  border-radius: 24px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
}

.bookBtn:hover {
  background-color: #e09513;
  transform: translateY(-1px);
}

.userAvatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  overflow: hidden;
  border: 2px solid rgba(255,255,255,0.3);
  transition: border-color 0.2s ease;
}

.avatarButton:hover .userAvatar,
.avatarButton:focus-visible .userAvatar {
  border-color: rgba(245,166,35,0.9);
}

.userAvatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.userDropdown {
  position: absolute;
  top: calc(100% + 12px);
  right: 0;
  width: 210px;
  padding: 8px;
  border-radius: 14px;
  background: rgba(24, 24, 24, 0.96);
  border: 1px solid rgba(255,255,255,0.12);
  backdrop-filter: blur(14px);
  box-shadow: 0 18px 45px rgba(0,0,0,0.45);
  display: flex;
  flex-direction: column;
  gap: 2px;
  z-index: 1050;
}

.userMenuDivider {
  height: 1px;
  background: rgba(255,255,255,0.09);
  margin: 4px 0;
  border-radius: 1px;
}

.userMenuItem {
  width: 100%;
  border: none;
  background: transparent;
  color: rgba(255,255,255,0.9);
  text-align: left;
  font-size: 13px;
  font-weight: 500;
  padding: 10px 12px;
  border-radius: 10px;
  cursor: pointer;
  transition: background 0.2s ease, color 0.2s ease;
  display: flex;
  align-items: center;
  gap: 9px;
}

.userMenuItemIcon {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  opacity: 0.75;
  transition: opacity 0.2s ease;
}

.userMenuItem:hover .userMenuItemIcon,
.userMenuItem:focus-visible .userMenuItemIcon {
  opacity: 1;
}

.userMenuItem:hover,
.userMenuItem:focus-visible {
  background: rgba(255,255,255,0.08);
  color: #ffffff;
}

.userMenuItem.danger {
  color: #ff8b8b;
}

.userMenuItem.danger:hover,
.userMenuItem.danger:focus-visible {
  background: rgba(255, 99, 99, 0.14);
  color: #ffb0b0;
}

.languageToggle {
  background: transparent;
  border: 1px solid rgba(255,255,255,0.3);
  color: #ffffff;
  padding: 6px 12px;
  border-radius: 16px;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
}

.languageToggle:hover {
  background: rgba(255,255,255,0.1);
  border-color: rgba(255,255,255,0.5);
}

.mobileMenuToggle {
  display: none;
  width: 36px;
  height: 36px;
  border-radius: 10px;
  border: 1px solid rgba(255,255,255,0.26);
  background: rgba(255,255,255,0.06);
  color: #ffffff;
  cursor: pointer;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 4px;
}

.mobileMenuToggle span {
  display: block;
  width: 16px;
  height: 1.7px;
  border-radius: 999px;
  background: currentColor;
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.mobileMenuToggle.open span:nth-child(1) {
  transform: translateY(6px) rotate(45deg);
}

.mobileMenuToggle.open span:nth-child(2) {
  opacity: 0;
}

.mobileMenuToggle.open span:nth-child(3) {
  transform: translateY(-6px) rotate(-45deg);
}

.mobileNavPanel {
  display: none;
}

.authDialogBackdrop {
  position: fixed;
  inset: 0;
  z-index: 2500;
  display: grid;
  place-items: center;
  padding: 24px;
  background: radial-gradient(circle at 20% 10%, rgba(245,166,35,0.18), transparent 42%), rgba(4, 4, 4, 0.78);
  backdrop-filter: blur(7px);
}

.authDialog {
  width: min(520px, 100%);
  border-radius: 20px;
  padding: 26px 24px;
  border: 1px solid rgba(255,255,255,0.16);
  background: linear-gradient(165deg, rgba(28,28,28,0.98) 0%, rgba(14,14,14,0.98) 100%);
  box-shadow: 0 26px 60px rgba(0,0,0,0.5);
}

.authDialogBadge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
  border-radius: 999px;
  padding: 6px 12px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #ffd188;
  border: 1px solid rgba(245,166,35,0.42);
  background: rgba(245,166,35,0.14);
}

.authDialog h3 {
  font-size: clamp(24px, 3.8vw, 32px);
  line-height: 1.15;
  margin-bottom: 10px;
}

.authDialog p {
  color: rgba(255,255,255,0.78);
  font-size: 15px;
  line-height: 1.6;
  margin-bottom: 20px;
}

.authDialogActions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
}

.authDialogSuccess {
  border-color: rgba(16,185,129,0.35);
  background: linear-gradient(165deg, rgba(16, 40, 31, 0.96) 0%, rgba(10, 20, 16, 0.98) 100%);
}

.reserveDialogBadge {
  display: inline-flex;
  align-items: center;
  margin-bottom: 12px;
  border-radius: 999px;
  padding: 6px 12px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #9ef3cb;
  border: 1px solid rgba(16,185,129,0.42);
  background: rgba(16,185,129,0.14);
}

.checkoutDialog {
  width: min(760px, 100%);
}

.checkoutDialogGrid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
  margin-bottom: 20px;
}

.checkoutCardBox {
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 14px;
  padding: 14px;
  background: rgba(255,255,255,0.03);
}

.checkoutCardBox h4 {
  font-size: 15px;
  margin-bottom: 10px;
}

.checkoutHint {
  margin-bottom: 10px;
  font-size: 13px;
  color: rgba(255,255,255,0.65);
}

.checkoutInfoRow {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  padding: 9px 0;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}

.checkoutInfoRow:last-child {
  border-bottom: none;
}

.checkoutInfoRow span {
  color: rgba(255,255,255,0.68);
  font-size: 13px;
}

.checkoutInfoRow strong {
  font-size: 13px;
  color: #ffffff;
  text-align: right;
}

.checkoutPaymentList {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.checkoutPaymentOption {
  width: 100%;
  border: 1px solid rgba(255,255,255,0.14);
  border-radius: 12px;
  background: rgba(255,255,255,0.02);
  color: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 12px;
  text-align: left;
  cursor: pointer;
  transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
}

.checkoutPaymentOption:hover {
  border-color: rgba(245,166,35,0.45);
  background: rgba(245,166,35,0.08);
  transform: translateY(-1px);
}

.checkoutPaymentOption p {
  margin: 0;
  font-size: 14px;
  color: #ffffff;
}

.checkoutPaymentOption span {
  font-size: 12px;
  color: rgba(255,255,255,0.66);
}

.checkoutPaymentOption.active {
  border-color: rgba(16,185,129,0.58);
  background: rgba(16,185,129,0.15);
}

.checkoutCheckMark {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #10b981;
  color: #03231a;
  font-weight: 800;
}

/* ═══════════════════════════════════════════════════════════════════════════════
   HERO SECTION - Premium Redesign (Webflow/Framer Style)
   ═══════════════════════════════════════════════════════════════════════════════ */
.hero {
  position: relative;
  height: 100vh;
  min-height: 700px;
  display: flex;
  align-items: center;
  justify-content: center;
  background-image: url('./assets/PrinImage.webp');
  background-size: cover;
  background-position: center;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: 
    radial-gradient(ellipse 80% 50% at 50% 0%, rgba(16,185,129,0.15) 0%, transparent 50%),
    radial-gradient(ellipse 60% 40% at 80% 80%, rgba(99,102,241,0.1) 0%, transparent 40%);
  pointer-events: none;
  z-index: 1;
}

.heroOverlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(0,0,0,0.5) 0%,
    rgba(0,0,0,0.3) 30%,
    rgba(0,0,0,0.4) 60%,
    rgba(10,10,10,0.95) 100%
  );
  z-index: 1;
}

.heroContent {
  position: relative;
  z-index: 2;
  text-align: center;
  max-width: 1100px;
  padding: 0 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32px;
}

/* Hero Title - Premium Typography */
.heroTitle {
  font-family: var(--font-heading, 'Poppins', sans-serif);
  font-size: clamp(40px, 6vw, 72px);
  font-weight: 800;
  line-height: 1.08;
  letter-spacing: -0.03em;
  margin: 0;
  background: linear-gradient(
    135deg,
    #ffffff 0%,
    #f0f9ff 25%,
    #e0f2fe 50%,
    #bae6fd 75%,
    #7dd3fc 100%
  );
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 80px rgba(16,185,129,0.3);
  animation: heroTitleFloat 6s ease-in-out infinite;
  max-width: 900px;
}

@keyframes heroTitleFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

.heroSubtitle {
  font-family: var(--font-main, 'Inter', sans-serif);
  font-size: clamp(16px, 2vw, 22px);
  font-weight: 400;
  color: rgba(224, 242, 254, 0.75);
  max-width: 600px;
  margin: 0;
  line-height: 1.7;
  letter-spacing: 0.01em;
  animation: heroSubtitleFade 1s ease-out 0.3s both;
}

@keyframes heroSubtitleFade {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Search Bar - Premium Glassmorphism */
.searchBar {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) 1px minmax(0, 1fr) 1px minmax(0, 1fr) 1px minmax(0, 0.9fr) auto;
  align-items: stretch;
  background: rgba(15, 23, 42, 0.75);
  backdrop-filter: blur(24px) saturate(180%);
  border-radius: 20px;
  padding: 8px;
  gap: 0;
  border: 1px solid rgba(255,255,255,0.12);
  max-width: 1100px;
  width: min(1100px, 95%);
  margin: 0 auto;
  box-shadow: 
    0 25px 50px -12px rgba(0,0,0,0.5),
    0 0 0 1px rgba(255,255,255,0.05) inset,
    0 1px 0 0 rgba(255,255,255,0.1) inset;
  animation: searchBarSlide 0.8s ease-out 0.5s both;
}

@keyframes searchBarSlide {
  from { 
    opacity: 0; 
    transform: translateY(30px) scale(0.95);
  }
  to { 
    opacity: 1; 
    transform: translateY(0) scale(1);
  }
}

.searchField {
  display: flex;
  align-items: center;
  gap: 0;
  min-width: 0;
  padding: 10px 18px;
  transition: background 0.2s ease;
  border-radius: 14px;
}

.searchField:hover {
  background: rgba(255,255,255,0.03);
}

.searchDivider {
  width: 1px;
  height: auto;
  margin: 12px 0;
  align-self: stretch;
  background: linear-gradient(
    to bottom,
    transparent 0%,
    rgba(255,255,255,0.2) 50%,
    transparent 100%
  );
}

.searchInputWrapper {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 4px;
  position: relative;
  width: 100%;
  min-width: 0;
}

.searchFieldLabel {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #34d399;
}

.searchFieldLabel svg {
  width: 14px;
  height: 14px;
  color: #34d399;
  flex-shrink: 0;
}

.calendarTrigger {
  width: 100%;
  min-height: 36px;
  border: none;
  padding: 0;
  background: transparent;
  color: rgba(255,255,255,0.95);
  display: inline-flex;
  align-items: center;
  justify-content: flex-start;
  cursor: pointer;
  font-family: inherit;
  font-size: 15px;
  font-weight: 600;
  line-height: 1.2;
  transition: color 0.2s ease, transform 0.2s ease;
}

.calendarTrigger:hover,
.calendarTrigger:focus-visible {
  color: #ffffff;
  transform: translateY(-1px);
}

.heroLocationInput {
  width: 100%;
  min-height: 36px;
  border: none;
  padding: 0;
  background: transparent;
  color: rgba(255, 255, 255, 0.95);
  font-family: inherit;
  font-size: 15px;
  font-weight: 600;
  line-height: 1.2;
  outline: none;
  transition: color 0.2s ease;
}

.heroLocationInput::placeholder {
  color: rgba(255, 255, 255, 0.45);
  font-weight: 500;
}

.heroLocationInput:focus {
  color: #ffffff;
}

.heroGuestsField {
  overflow: visible;
}

.heroGuestsTrigger {
  width: 100%;
  min-height: 36px;
  border: none;
  border-radius: 0;
  padding: 0 24px 0 0;
  background:
    linear-gradient(45deg, transparent 50%, #34d399 50%),
    linear-gradient(135deg, #34d399 50%, transparent 50%);
  background-position:
    calc(100% - 14px) calc(50% - 1px),
    calc(100% - 9px) calc(50% - 1px);
  background-size: 5px 5px, 5px 5px;
  background-repeat: no-repeat;
  color: rgba(255, 255, 255, 0.95);
  font-family: inherit;
  font-size: 15px;
  font-weight: 600;
  line-height: 1.2;
  outline: none;
  cursor: text;
  box-shadow: none;
  transition: color 0.2s ease;
  text-align: left;
}

.heroGuestsTrigger::placeholder {
  color: rgba(255, 255, 255, 0.45);
  font-weight: 500;
}

.searchButton {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #ffffff;
  border: none;
  width: 56px;
  min-width: 56px;
  min-height: 52px;
  padding: 0;
  border-radius: 14px;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10px 25px -5px rgba(16,185,129,0.4);
}

.searchButton svg {
  width: 22px;
  height: 22px;
  transition: transform 0.3s ease;
}

.searchButton:hover {
  transform: translateY(-2px) scale(1.02);
  box-shadow: 0 20px 35px -5px rgba(16,185,129,0.5);
}

.searchButton:hover svg {
  transform: scale(1.1);
}

.searchButton:active {
  transform: translateY(0) scale(0.98);
}

/* Location Dropdown */
.heroLocationMenu {
  position: absolute;
  top: calc(100% + 12px);
  left: 0;
  min-width: 280px;
  z-index: 2600;
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 10px;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(15, 23, 42, 0.98);
  box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
  backdrop-filter: blur(20px);
  animation: dropdownSlide 0.2s ease;
}

@keyframes dropdownSlide {
  from { opacity: 0; transform: translateY(-8px); }
  to { opacity: 1; transform: translateY(0); }
}

.heroLocationOption {
  width: 100%;
  border: none;
  border-radius: 10px;
  padding: 12px 14px;
  background: transparent;
  color: rgba(255,255,255,0.9);
  text-align: left;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.15s ease;
  display: flex;
  align-items: center;
  gap: 10px;
}

.heroLocationOption::before {
  content: '📍';
  font-size: 14px;
  opacity: 0.7;
}

.heroLocationOption:hover {
  background: rgba(16,185,129,0.15);
  color: #ffffff;
  transform: translateX(4px);
}

/* Guests Menu */
.heroGuestsMenu {
  position: absolute;
  top: calc(100% + 12px);
  left: 0;
  right: 0;
  z-index: 2600;
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 10px;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(15, 23, 42, 0.98);
  box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
  backdrop-filter: blur(20px);
  animation: dropdownSlide 0.2s ease;
  max-height: 280px;
  overflow-y: auto;
}

.heroGuestsOption {
  width: 100%;
  border: none;
  border-radius: 10px;
  padding: 10px 14px;
  background: transparent;
  color: rgba(255,255,255,0.9);
  text-align: left;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s ease;
}

.heroGuestsOption:hover {
  background: rgba(16,185,129,0.15);
  color: #ffffff;
}

.heroGuestsOption.active {
  background: rgba(16,185,129,0.2);
  color: #34d399;
}

/* Availability Modal */
.availabilityModalBackdrop {
  position: fixed;
  inset: 0;
  z-index: 2450;
  display: grid;
  place-items: center;
  background: radial-gradient(circle at 50% 20%, rgba(13, 28, 48, 0.4), rgba(3, 8, 14, 0.7));
  backdrop-filter: blur(10px);
  padding: 20px;
  animation: modalBackdropFade 0.3s ease;
}

@keyframes modalBackdropFade {
  from { opacity: 0; }
  to { opacity: 1; }
}

.availabilityModalCard {
  width: min(860px, 100%);
  border-radius: 28px;
  padding: 32px 32px 28px;
  text-align: left;
  border: 1px solid rgba(255, 255, 255, 0.15);
  background: linear-gradient(165deg, rgba(15, 23, 42, 0.98), rgba(10, 15, 30, 0.97));
  box-shadow: 
    0 40px 100px rgba(0, 0, 0, 0.6),
    0 0 0 1px rgba(255,255,255,0.05) inset;
  position: relative;
  animation: modalCardPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  overflow: hidden;
}

@keyframes modalCardPop {
  0% { transform: scale(0.9) translateY(20px); opacity: 0; }
  100% { transform: scale(1) translateY(0); opacity: 1; }
}

.availabilityModalGlow {
  position: absolute;
  width: 400px;
  height: 400px;
  right: -150px;
  top: -200px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(99, 187, 255, 0.25), transparent 60%);
  pointer-events: none;
  animation: glowPulse 3s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50% { opacity: 0.8; transform: scale(1.1); }
}

.availabilityModalCard.available {
  border-color: rgba(16, 185, 129, 0.5);
  background: linear-gradient(165deg, rgba(6, 45, 35, 0.98), rgba(5, 25, 20, 0.97));
}

.availabilityModalCard.available .availabilityModalGlow {
  background: radial-gradient(circle, rgba(52, 211, 153, 0.25), transparent 60%);
}

.availabilityModalCard.unavailable {
  border-color: rgba(248, 113, 113, 0.5);
  background: linear-gradient(165deg, rgba(50, 15, 20, 0.98), rgba(30, 10, 15, 0.97));
}

.availabilityModalCard.unavailable .availabilityModalGlow {
  background: radial-gradient(circle, rgba(248, 113, 113, 0.25), transparent 60%);
}

.availabilityModalState {
  margin-bottom: 16px;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 8px 14px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  color: rgba(230, 245, 255, 0.95);
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.15);
  animation: stateSlide 0.5s ease 0.1s both;
}

@keyframes stateSlide {
  from { opacity: 0; transform: translateX(-20px); }
  to { opacity: 1; transform: translateX(0); }
}

.availabilityModalStateDot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #6dd0ff;
  animation: dotPulse 2s ease-in-out infinite;
}

.availabilityModalCard.available .availabilityModalStateDot {
  background: #34d399;
}

.availabilityModalCard.unavailable .availabilityModalStateDot {
  background: #f87171;
}

@keyframes dotPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.7; transform: scale(1.2); }
}

.availabilityModalCard strong {
  display: block;
  margin-bottom: 8px;
  font-size: clamp(26px, 3.5vw, 34px);
  font-weight: 700;
  line-height: 1.2;
  background: linear-gradient(135deg, #ffffff 0%, #bae6fd 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.availabilityModalCard p {
  margin: 0;
  font-size: 15px;
  color: rgba(200, 220, 240, 0.8);
  line-height: 1.6;
}

.availabilityModalLayout {
  margin-top: 12px;
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(260px, 0.9fr);
  gap: 24px;
  align-items: start;
}

.availabilityModalMain {
  min-height: 190px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.availabilityListingsWrap {
  margin-top: 0;
  padding: 18px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.05);
  animation: listingsWrapSlide 0.5s ease 0.2s both;
}

@keyframes listingsWrapSlide {
  from { opacity: 0; transform: translateY(15px); }
  to { opacity: 1; transform: translateY(0); }
}

.availabilityListingsLabel {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: rgba(180, 210, 240, 0.7);
  margin-bottom: 12px;
  font-weight: 600;
}

.availabilityListingsChips {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.availabilityListingChip {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 8px 14px;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.95);
  font-size: 13px;
  font-weight: 600;
  transition: all 0.2s ease;
  animation: chipFade 0.4s ease both;
}

.availabilityListingChip:nth-child(1) { animation-delay: 0.3s; }
.availabilityListingChip:nth-child(2) { animation-delay: 0.4s; }
.availabilityListingChip:nth-child(3) { animation-delay: 0.5s; }

@keyframes chipFade {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

.availabilityListingChip:hover {
  background: rgba(255, 255, 255, 0.15);
  transform: translateY(-2px);
}

.availabilityModalClose {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 40px;
  height: 40px;
  border: none;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  font-size: 22px;
  line-height: 1;
  cursor: pointer;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.availabilityModalClose:hover {
  background: rgba(255, 255, 255, 0.15);
  transform: rotate(90deg);
}

.availabilityShowBtn {
  margin-top: 20px;
  border: none;
  border-radius: 14px;
  padding: 14px 24px;
  font-size: 15px;
  font-weight: 700;
  background: linear-gradient(135deg, #3a7bff, #2b5fe3);
  color: #ffffff;
  cursor: pointer;
  box-shadow: 0 14px 28px rgba(45, 106, 255, 0.35);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  align-self: flex-start;
}

.availabilityShowBtn:hover {
  transform: translateY(-2px);
  box-shadow: 0 20px 40px rgba(45, 106, 255, 0.45);
}

/* Date Picker Premium Styles */
.heroDatePickerPopper {
  z-index: 2600;
  margin-top: 12px;
}

.heroDatePickerPopper .react-datepicker__triangle {
  display: none;
}

.heroDatePickerCalendar.react-datepicker {
  border: none;
  border-radius: 24px;
  background: #f8fafc;
  box-shadow: 0 25px 50px -12px rgba(0,0,0,0.35);
  overflow: hidden;
  padding: 0;
  font-family: var(--font-main);
}

.heroDatePickerCalendar .react-datepicker__month-container {
  width: 300px;
}

.heroDatePickerCalendar .react-datepicker__header {
  background: #f8fafc;
  border-bottom: 1px solid #e2e8f0;
  padding: 16px 16px 10px;
}

.heroDatePickerCalendar .react-datepicker__current-month,
.heroDatePickerCalendar .react-datepicker__navigation {
  display: none;
}

.heroCalendarHeaderControls {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 10px;
}

.heroCalendarSelect {
  width: 100%;
  border: 1px solid #e2e8f0;
  background: #f1f5f9;
  color: #0f172a;
  border-radius: 12px;
  padding: 10px 14px;
  font-size: 13px;
  font-weight: 700;
  outline: none;
  appearance: none;
  background-image:
    linear-gradient(45deg, transparent 50%, #64748b 50%),
    linear-gradient(135deg, #64748b 50%, transparent 50%);
  background-position:
    calc(100% - 18px) calc(50% - 1px),
    calc(100% - 13px) calc(50% - 1px);
  background-size: 5px 5px, 5px 5px;
  background-repeat: no-repeat;
  transition: all 0.2s ease;
}

.heroCalendarSelect:hover {
  border-color: #cbd5e1;
  background-color: #e2e8f0;
}

.heroCalendarSelect:focus {
  border-color: #10b981;
  box-shadow: 0 0 0 3px rgba(16,185,129,0.1);
}

.heroDatePickerCalendar .react-datepicker__day-names {
  margin-top: 4px;
}

.heroDatePickerCalendar .react-datepicker__day-name {
  color: #94a3b8;
  width: 2.2rem;
  margin: 0.1rem;
  font-size: 11px;
  font-weight: 700;
  line-height: 1.8rem;
}

.heroDatePickerCalendar .react-datepicker__month {
  margin: 0;
  padding: 12px 16px 16px;
}

.heroDatePickerCalendar .react-datepicker__week {
  display: flex;
  justify-content: space-between;
}

.heroDatePickerCalendar .react-datepicker__day {
  width: 2.2rem;
  height: 2.2rem;
  line-height: 2.2rem;
  margin: 0.1rem;
  border-radius: 999px;
  background: transparent;
  color: #1e293b;
  font-size: 13px;
  font-weight: 600;
  transition: all 0.15s ease;
}

.heroDatePickerCalendar .react-datepicker__day:hover {
  background: #e2e8f0;
  transform: scale(1.05);
}

.heroDatePickerCalendar .react-datepicker__day--outside-month {
  color: #cbd5e1;
}

.heroDatePickerCalendar .react-datepicker__day--disabled {
  color: #e2e8f0;
  cursor: not-allowed;
}

.heroDatePickerCalendar .react-datepicker__day--disabled:hover {
  background: transparent;
  transform: none;
}

.heroDayBubble {
  width: 2.2rem;
  height: 2.2rem;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.heroDatePickerCalendar .react-datepicker__day.heroDayInRange .heroDayBubble {
  background: #dcfce7;
  color: #166534;
  animation: heroRangePaint 360ms cubic-bezier(0.22, 0.8, 0.3, 1) both;
  animation-delay: calc(var(--hero-range-step, 0) * 45ms);
}

.heroDatePickerCalendar .react-datepicker__day.heroDayPreview .heroDayBubble {
  background: #ecfdf5;
  color: #15803d;
  animation: heroRangePaint 320ms cubic-bezier(0.2, 0.78, 0.25, 1) both;
  animation-delay: calc(var(--hero-range-step, 0) * 28ms);
}

.heroDatePickerCalendar .react-datepicker__day.heroDayRangeStart .heroDayBubble,
.heroDatePickerCalendar .react-datepicker__day.heroDayRangeEnd .heroDayBubble,
.heroDatePickerCalendar .react-datepicker__day--selected .heroDayBubble,
.heroDatePickerCalendar .react-datepicker__day--keyboard-selected .heroDayBubble {
  background: #10b981;
  color: #ffffff;
  box-shadow: 0 8px 16px rgba(16, 185, 129, 0.35);
}

.heroDatePickerCalendar .react-datepicker__day.heroDayPreview.heroDayRangeStart .heroDayBubble,
.heroDatePickerCalendar .react-datepicker__day.heroDayPreview.heroDayRangeEnd .heroDayBubble {
  background: #34d399;
}

.heroDatePickerCalendar .react-datepicker__day.heroDayRangeStart .heroDayBubble,
.heroDatePickerCalendar .react-datepicker__day.heroDayRangeEnd .heroDayBubble {
  box-shadow: 0 8px 20px rgba(16, 185, 129, 0.4);
}

@keyframes heroRangePaint {
  0% { transform: scale(0.25); opacity: 0; }
  70% { transform: scale(1.08); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}

.heroDatePickerCalendar .react-datepicker__day--today {
  border: 1px solid #cbd5e1;
}

/* ═══════════════════════════════════════════════════════════════════════════════
   PROFILE DASHBOARD - Premium Redesign (Webflow/Framer Style)
   ═══════════════════════════════════════════════════════════════════════════════ */

/* Page shell with premium gradient background */
.profileDashPage {
  min-height: 100vh;
  background: 
    radial-gradient(ellipse 80% 50% at 10% 0%, rgba(16,185,129,0.08) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 90% 100%, rgba(99,102,241,0.06) 0%, transparent 55%),
    radial-gradient(ellipse 50% 30% at 50% 100%, rgba(16,185,129,0.05) 0%, transparent 50%),
    #05070b;
  color: #e2e8f0;
  display: flex;
  flex-direction: column;
  font-family: var(--font-main, 'Inter', system-ui, sans-serif);
}

.profileDashPage.hostDashPage {
  background: 
    radial-gradient(ellipse 80% 50% at 15% 0%, rgba(245,166,35,0.06) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 85% 100%, rgba(99,102,241,0.05) 0%, transparent 55%),
    #05070b;
}

/* Layout */
.profileDashLayout {
  width: 100%;
  max-width: 1440px;
  margin: 0 auto;
  padding: 28px 32px 48px;
  display: grid;
  grid-template-columns: 280px minmax(0, 1fr);
  gap: 32px;
  flex: 1;
  align-items: start;
}

/* Sidebar Toggle Button */
.sidebarToggleBtn {
  display: none;
}

/* ── Sidebar ─────────────────────────────────────────── */
.profileDashSidebar {
  position: sticky;
  top: 24px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  animation: sidebarSlide 0.6s ease-out;
}

@keyframes sidebarSlide {
  from { opacity: 0; transform: translateX(-30px); }
  to { opacity: 1; transform: translateX(0); }
}

.profileDashUserBlock {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 20px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 20px;
  margin-bottom: 12px;
  transition: all 0.3s ease;
}

.profileDashUserBlock:hover {
  background: rgba(255,255,255,0.05);
  border-color: rgba(255,255,255,0.12);
  transform: translateY(-2px);
  box-shadow: 0 20px 40px rgba(0,0,0,0.3);
}

.profileDashUserPhoto {
  width: 56px;
  height: 56px;
  border-radius: 16px;
  object-fit: cover;
  border: 2px solid rgba(16,185,129,0.4);
  box-shadow: 0 4px 15px rgba(16,185,129,0.2);
  transition: all 0.3s ease;
}

.profileDashUserBlock:hover .profileDashUserPhoto {
  transform: scale(1.05);
  border-color: rgba(16,185,129,0.6);
}

.profileDashUserBlock h2 {
  margin: 0;
  font-size: 17px;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: #f8fafc;
}

.profileDashUserBlock span {
  display: inline-block;
  margin-top: 6px;
  border-radius: 999px;
  padding: 4px 12px;
  background: linear-gradient(135deg, rgba(16,185,129,0.2), rgba(5,150,105,0.15));
  border: 1px solid rgba(16,185,129,0.3);
  color: #34d399;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

/* Sidebar Navigation */
.profileDashMenu {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.profileDashMenu li {
  border-radius: 14px;
  font-size: 14px;
  color: rgba(148,163,184,0.8);
  font-weight: 500;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.profileDashMenu li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 3px;
  height: 0;
  background: linear-gradient(180deg, #10b981, #34d399);
  border-radius: 0 99px 99px 0;
  transition: height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.profileDashMenuBtn {
  width: 100%;
  background: transparent;
  border: none;
  color: inherit;
  text-align: left;
  padding: 12px 16px;
  font: inherit;
  font-size: 14px;
  cursor: pointer;
  border-radius: 14px;
  display: flex;
  align-items: center;
  gap: 12px;
  transition: all 0.2s ease;
}

.profileDashMenuBtn:hover {
  background: rgba(255,255,255,0.05);
  color: #e2e8f0;
  transform: translateX(4px);
}

.profileDashMenu li.active {
  background: rgba(16,185,129,0.1);
}

.profileDashMenu li.active::before {
  height: 24px;
}

.profileDashMenu li.active .profileDashMenuBtn {
  color: #34d399;
  font-weight: 600;
  background: transparent;
}

/* Reserve Button */
.profileDashReserveBtn {
  margin-top: 16px;
  width: 100%;
  border: none;
  border-radius: 14px;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #fff;
  font-size: 14px;
  font-weight: 700;
  padding: 14px 18px;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 8px 25px rgba(16,185,129,0.35);
  letter-spacing: 0.01em;
  position: relative;
  overflow: hidden;
}

.profileDashReserveBtn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  transition: left 0.5s ease;
}

.profileDashReserveBtn:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 35px rgba(16,185,129,0.45);
}

.profileDashReserveBtn:hover::before {
  left: 100%;
}

.profileDashReserveBtn:active {
  transform: translateY(0);
}

/* ── Main Content Area ───────────────────────────────── */
.profileDashMain {
  min-width: 0;
  animation: mainFade 0.6s ease-out 0.1s both;
}

@keyframes mainFade {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.profileDashBackRow {
  display: flex;
  align-items: center;
  margin-bottom: 24px;
}

.catalogClose {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.03);
  color: #94a3b8;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.catalogClose:hover {
  background: rgba(255,255,255,0.08);
  border-color: rgba(255,255,255,0.15);
  color: #e2e8f0;
  transform: translateX(-3px);
}

.catalogClose svg {
  width: 20px;
  height: 20px;
}

/* Section Headings */
.profileDashHeading {
  margin-bottom: 32px;
  padding-bottom: 24px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.profileDashHeading h1 {
  font-family: var(--font-heading, 'Poppins', sans-serif);
  margin: 0;
  font-size: clamp(28px, 3.5vw, 36px);
  font-weight: 700;
  letter-spacing: -0.025em;
  background: linear-gradient(135deg, #f8fafc 0%, #cbd5e1 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.profileDashHeading p {
  margin-top: 10px;
  color: rgba(148,163,184,0.8);
  font-size: 15px;
  line-height: 1.6;
}

/* Personal Header with Actions */
.profileDashPersonalHeader {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
}

.profileDashPersonalActions {
  display: flex;
  gap: 10px;
  flex-shrink: 0;
}

/* Buttons - Premium */
.profileDashSecondaryBtn,
.profileDashPrimaryBtn {
  border-radius: 12px;
  padding: 10px 20px;
  font-size: 13px;
  font-weight: 700;
  font-family: inherit;
  letter-spacing: 0.01em;
  cursor: pointer;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.profileDashSecondaryBtn {
  border: 1px solid rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.03);
  color: #cbd5e1;
}

.profileDashSecondaryBtn:hover {
  border-color: rgba(255,255,255,0.2);
  background: rgba(255,255,255,0.07);
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(0,0,0,0.2);
}

.profileDashSecondaryBtn.danger:hover {
  border-color: rgba(239,68,68,0.4);
  background: rgba(239,68,68,0.1);
  color: #f87171;
}

.profileDashPrimaryBtn {
  border: none;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #fff;
  box-shadow: 0 8px 25px rgba(16,185,129,0.35);
}

.profileDashPrimaryBtn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  transition: left 0.5s ease;
}

.profileDashPrimaryBtn:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 35px rgba(16,185,129,0.45);
}

.profileDashPrimaryBtn:hover::before {
  left: 100%;
}

.profileDashPrimaryBtn:active,
.profileDashSecondaryBtn:active {
  transform: translateY(0);
}

/* ── Tabs ────────────────────────────────────────────── */
.profileDashTabs {
  margin-bottom: 28px;
  display: flex;
  gap: 4px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 14px;
  padding: 5px;
  width: fit-content;
}

.profileDashTabs button {
  border: none;
  background: transparent;
  color: rgba(148,163,184,0.7);
  padding: 10px 20px;
  font-size: 14px;
  font-weight: 600;
  font-family: inherit;
  cursor: pointer;
  border-radius: 10px;
  transition: all 0.2s ease;
  white-space: nowrap;
}

.profileDashTabs button:hover {
  color: rgba(226,232,240,0.9);
  background: rgba(255,255,255,0.04);
}

.profileDashTabs button.active {
  background: rgba(16,185,129,0.15);
  color: #34d399;
  box-shadow: 0 2px 8px rgba(16,185,129,0.15);
}

.profileDashTabs button span {
  margin-left: 8px;
  border-radius: 999px;
  background: rgba(16,185,129,0.25);
  color: #6ee7b7;
  font-size: 11px;
  font-weight: 700;
  padding: 2px 8px;
}

/* ── Trip Cards ──────────────────────────────────────── */
.profileDashTripCards {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.profileDashTripCard {
  border-radius: 24px;
  border: 1px solid rgba(255,255,255,0.06);
  overflow: hidden;
  background: rgba(15, 23, 42, 0.5);
  backdrop-filter: blur(10px);
  display: grid;
  grid-template-columns: minmax(220px,30%) minmax(0,1fr);
  height: 210px;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  cursor: pointer;
  position: relative;
}

.profileDashTripCard::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 24px;
  padding: 1px;
  background: linear-gradient(135deg, rgba(255,255,255,0.1), transparent 50%);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

.profileDashTripCard:hover {
  transform: translateY(-4px);
  box-shadow: 0 30px 60px rgba(0,0,0,0.4);
  border-color: rgba(16,185,129,0.2);
}

.profileDashTripCard img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.profileDashTripCard:hover img {
  transform: scale(1.05);
}

.profileDashTripInfo {
  padding: 24px 28px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.profileDashTripLocation {
  margin: 0;
  text-transform: uppercase;
  color: #34d399;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  display: flex;
  align-items: center;
  gap: 8px;
}

.profileDashTripLocation::before {
  content: '';
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #34d399;
}

.profileDashTripInfo h3 {
  margin: 10px 0 0;
  font-size: 20px;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: #f8fafc;
}

.profileDashTripMeta {
  margin-top: 8px;
  color: rgba(148,163,184,0.7);
  font-size: 14px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.profileDashTripActions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
}

.profileDashTripActions button {
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.03);
  color: #cbd5e1;
  border-radius: 10px;
  padding: 10px 18px;
  font-weight: 600;
  font-size: 13px;
  font-family: inherit;
  cursor: pointer;
  transition: all 0.2s ease;
}

.profileDashTripActions button:hover {
  background: rgba(255,255,255,0.07);
  border-color: rgba(255,255,255,0.15);
  transform: translateY(-1px);
}

.profileDashTripActions button.primary {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-color: transparent;
  color: #fff;
  box-shadow: 0 4px 15px rgba(16,185,129,0.3);
}

.profileDashTripActions button.primary:hover {
  box-shadow: 0 8px 25px rgba(16,185,129,0.4);
  transform: translateY(-2px);
}

/* ── Personal / Settings Cards ───────────────────────── */
.profileDashPersonalSection,
.profileDashSecuritySection,
.profileDashPaymentsSection,
.profileDashFavoritesSection,
.hostManageStaysSection {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.profileDashPersonalCard {
  padding: 28px 32px;
  border-radius: 24px;
  border: 1px solid rgba(255,255,255,0.06);
  background: rgba(15, 23, 42, 0.4);
  backdrop-filter: blur(12px);
  transition: all 0.3s ease;
  position: relative;
}

.profileDashPersonalCard::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 24px;
  padding: 1px;
  background: linear-gradient(135deg, rgba(255,255,255,0.08), transparent 40%);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

.profileDashPersonalCard:hover {
  border-color: rgba(255,255,255,0.1);
  background: rgba(15, 23, 42, 0.5);
  transform: translateY(-2px);
  box-shadow: 0 20px 40px rgba(0,0,0,0.25);
}

.profileDashPersonalCard h2 {
  margin: 0;
  font-size: 17px;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: #f1f5f9;
  display: flex;
  align-items: center;
  gap: 10px;
}

.profileDashPersonalCard h2::before {
  content: '';
  display: inline-block;
  width: 4px;
  height: 18px;
  border-radius: 99px;
  background: linear-gradient(180deg, #10b981, #34d399);
  flex-shrink: 0;
}

.profileDashPersonalCard > p {
  margin: 12px 0 0;
  color: rgba(148,163,184,0.7);
  font-size: 14px;
  line-height: 1.6;
}

/* Setting rows */
.profileDashSettingList {
  list-style: none;
  margin: 24px 0 0;
  padding: 0;
  display: flex;
  flex-direction: column;
}

.profileDashSettingList li {
  display: grid;
  grid-template-columns: 180px 1fr auto;
  gap: 20px;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  transition: all 0.2s ease;
  border-radius: 0;
}

.profileDashSettingList li:last-child {
  border-bottom: none;
}

.profileDashSettingList li:hover {
  background: rgba(255,255,255,0.02);
  margin: 0 -12px;
  padding-left: 12px;
  padding-right: 12px;
  border-radius: 12px;
}

.profileDashSettingList span {
  color: rgba(148,163,184,0.7);
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.profileDashSettingList strong {
  font-size: 15px;
  color: #e2e8f0;
  font-weight: 500;
}

.profileDashSettingList input,
.profileDashSettingList select {
  width: 100%;
  max-width: 320px;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.03);
  color: #f1f5f9;
  border-radius: 10px;
  padding: 10px 14px;
  font-size: 14px;
  font-family: inherit;
  outline: none;
  transition: all 0.2s ease;
}

.profileDashSettingList input:focus,
.profileDashSettingList select:focus {
  border-color: rgba(16,185,129,0.5);
  background: rgba(16,185,129,0.05);
  box-shadow: 0 0 0 3px rgba(16,185,129,0.1);
}

.profileDashSettingList .chevron {
  font-size: 22px;
  color: rgba(148,163,184,0.4);
  text-transform: none;
  font-style: normal;
  transition: all 0.2s ease;
}

.profileDashSettingList li:hover .chevron {
  color: rgba(16,185,129,0.6);
  transform: translateX(4px);
}

/* Inline fields */
.profileDashInlineFields {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  max-width: 320px;
}

/* Toggle switch */
.profileDashToggleRow {
  margin-top: 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 6px 0;
}

.profileDashToggleRow > span {
  font-size: 15px;
  color: rgba(203,213,225,0.9);
  font-weight: 500;
}

.profileDashSwitch {
  position: relative;
  width: 52px;
  height: 30px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.05);
  padding: 0;
  cursor: pointer;
  flex-shrink: 0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.profileDashSwitch span {
  position: absolute;
  top: 4px;
  left: 4px;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: linear-gradient(135deg, #94a3b8, #64748b);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2px 8px rgba(0,0,0,0.3);
}

.profileDashSwitch.on {
  background: linear-gradient(135deg, rgba(16,185,129,0.8), rgba(5,150,105,0.8));
  border-color: rgba(16,185,129,0.4);
  box-shadow: 0 0 0 3px rgba(16,185,129,0.15);
}

.profileDashSwitch.on span {
  transform: translateX(22px);
  background: #ffffff;
}

.profileDashSecurityInfo {
  margin-top: 16px;
  padding: 14px 18px;
  background: rgba(16,185,129,0.08);
  border: 1px solid rgba(16,185,129,0.2);
  border-radius: 12px;
  color: rgba(110,231,183,0.95);
  font-size: 14px;
  line-height: 1.5;
}

.profileDashSecurityActionRow {
  margin-top: 24px;
  display: flex;
  justify-content: flex-end;
}

/* Tiny buttons */
.profileDashTinyBtn {
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.03);
  color: #94a3b8;
  border-radius: 8px;
  padding: 7px 14px;
  font-size: 12px;
  font-weight: 700;
  font-family: inherit;
  cursor: pointer;
  transition: all 0.2s ease;
  white-space: nowrap;
}

.profileDashTinyBtn:hover {
  background: rgba(255,255,255,0.07);
  border-color: rgba(255,255,255,0.15);
  transform: translateY(-1px);
}

.profileDashTinyBtn.active {
  border-color: rgba(16,185,129,0.5);
  background: rgba(16,185,129,0.15);
  color: #6ee7b7;
}

/* ── Favorites ───────────────────────────────────────── */
.profileDashFavoritesGrid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 20px;
}

.profileDashFavoriteCard {
  position: relative;
  overflow: hidden;
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.06);
  background: rgba(15, 23, 42, 0.5);
  backdrop-filter: blur(10px);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.profileDashFavoriteCard::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 20px;
  padding: 1px;
  background: linear-gradient(135deg, rgba(255,255,255,0.08), transparent 50%);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

.profileDashFavoriteCard:hover {
  transform: translateY(-6px);
  box-shadow: 0 30px 60px rgba(0,0,0,0.35);
  border-color: rgba(16,185,129,0.15);
}

.profileDashFavoriteCard img {
  width: 100%;
  height: 200px;
  object-fit: cover;
  display: block;
  transition: transform 0.6s ease;
}

.profileDashFavoriteCard:hover img {
  transform: scale(1.05);
}

.profileDashFavoriteHeart {
  position: absolute;
  top: 14px;
  right: 14px;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.2);
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(10px);
  color: #f43f5e;
  font-size: 18px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.profileDashFavoriteHeart:hover {
  background: rgba(244,63,94,0.2);
  transform: scale(1.15);
  border-color: rgba(244,63,94,0.4);
}

.profileDashFavoriteContent {
  padding: 18px 20px 20px;
}

.profileDashFavoriteContent h3 {
  margin: 0;
  font-size: 17px;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: #f8fafc;
}

.profileDashFavoriteContent p {
  margin-top: 6px;
  font-size: 14px;
  color: rgba(148,163,184,0.8);
}

.profileDashFavoriteActions {
  margin-top: 16px;
  display: flex;
  gap: 10px;
}

/* ── Host Dashboard Stats ────────────────────────────── */
.hostDashStatsGrid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-bottom: 28px;
}

.hostDashStatCard {
  padding: 24px;
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.06);
  background: rgba(15, 23, 42, 0.4);
  backdrop-filter: blur(10px);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.hostDashStatCard::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, #10b981, #34d399);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.hostDashStatCard:hover {
  transform: translateY(-4px);
  border-color: rgba(16,185,129,0.2);
  box-shadow: 0 20px 40px rgba(0,0,0,0.25);
}

.hostDashStatCard:hover::before {
  opacity: 1;
}

.hostDashStatCard p {
  margin: 0 0 8px;
  font-size: 13px;
  color: rgba(148,163,184,0.8);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-weight: 600;
}

.hostDashStatCard h3 {
  margin: 0;
  font-size: 32px;
  font-weight: 700;
  color: #f8fafc;
  background: linear-gradient(135deg, #f8fafc, #cbd5e1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Host Dashboard Panels */
.hostDashPanel {
  padding: 28px 32px;
  border-radius: 24px;
  border: 1px solid rgba(255,255,255,0.06);
  background: rgba(15, 23, 42, 0.4);
  backdrop-filter: blur(10px);
}

.hostDashPanel h2 {
  margin: 0 0 24px;
  font-size: 20px;
  font-weight: 700;
  color: #f8fafc;
}

/* KPI Grid */
.hostDashKpiGrid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}

.hostDashKpiCard {
  padding: 20px;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.06);
  background: rgba(255,255,255,0.02);
  transition: all 0.2s ease;
}

.hostDashKpiCard:hover {
  background: rgba(255,255,255,0.04);
  transform: translateY(-2px);
}

.hostDashKpiCard p {
  margin: 0 0 6px;
  font-size: 12px;
  color: rgba(148,163,184,0.8);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.hostDashKpiCard strong {
  font-size: 22px;
  font-weight: 700;
  color: #f8fafc;
}

/* Reservation List */
.hostDashReservationList {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.hostDashReservationList li {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,0.05);
  background: rgba(255,255,255,0.02);
  transition: all 0.2s ease;
}

.hostDashReservationList li:hover {
  background: rgba(255,255,255,0.04);
  border-color: rgba(255,255,255,0.08);
  transform: translateX(4px);
}

.hostDashReservationList li strong {
  font-size: 15px;
  font-weight: 600;
  color: #f1f5f9;
}

.hostDashReservationList li p {
  margin: 4px 0 0;
  font-size: 13px;
  color: rgba(148,163,184,0.7);
}

.hostDashReservationList li span {
  font-size: 13px;
  font-weight: 600;
  padding: 6px 12px;
  border-radius: 999px;
  background: rgba(16,185,129,0.15);
  color: #34d399;
}

/* Export Actions */
.hostDashExportActions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

/* Stay Management */
.listingsGrid.improvedGrid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 24px;
}

.listingCard.improvedCard {
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.06);
  background: rgba(15, 23, 42, 0.4);
  backdrop-filter: blur(10px);
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.listingCard.improvedCard:hover {
  transform: translateY(-6px);
  box-shadow: 0 30px 60px rgba(0,0,0,0.3);
  border-color: rgba(16,185,129,0.15);
}

.listingCard.improvedCard .listingImage {
  height: 180px;
  overflow: hidden;
}

.listingCard.improvedCard .listingImage img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.listingCard.improvedCard:hover .listingImage img {
  transform: scale(1.05);
}

.listingCard.improvedCard .listingInfo {
  padding: 20px;
}

.listingCard.improvedCard .listingInfo h3 {
  margin: 0 0 8px;
  font-size: 18px;
  font-weight: 700;
  color: #f8fafc;
}

.listingCard.improvedCard .listingLocation {
  font-size: 13px;
  color: rgba(148,163,184,0.8);
  margin-bottom: 8px;
}

.listingCard.improvedCard .listingPrice {
  font-size: 16px;
  font-weight: 700;
  color: #34d399;
  margin-bottom: 12px;
}

.listingCard.improvedCard .listingDescription {
  font-size: 13px;
  color: rgba(148,163,184,0.8);
  line-height: 1.5;
  margin-bottom: 16px;
}

.listingCard.improvedCard .listingAmenities {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
}

.amenityTag {
  padding: 6px 12px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 600;
  background: rgba(16,185,129,0.1);
  color: #34d399;
  border: 1px solid rgba(16,185,129,0.2);
}

.listingActions {
  display: flex;
  gap: 10px;
}

/* Add/Edit Modal */
.hostAddStayModal,
.hostEditStayModal {
  position: fixed;
  inset: 0;
  z-index: 3000;
  display: grid;
  place-items: center;
  background: rgba(5, 7, 11, 0.8);
  backdrop-filter: blur(10px);
  padding: 20px;
  animation: modalBackdropFade 0.3s ease;
}

.hostAddStayForm {
  width: min(520px, 100%);
  padding: 32px;
  border-radius: 24px;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(15, 23, 42, 0.95);
  backdrop-filter: blur(20px);
  box-shadow: 0 40px 80px rgba(0,0,0,0.5);
  animation: modalCardPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

.hostAddStayForm h2 {
  margin: 0 0 24px;
  font-size: 24px;
  font-weight: 700;
  color: #f8fafc;
}

.hostAddStayForm label {
  display: block;
  margin-bottom: 16px;
  font-size: 13px;
  font-weight: 600;
  color: rgba(148,163,184,0.9);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.hostAddStayForm input,
.hostAddStayForm textarea {
  width: 100%;
  margin-top: 8px;
  padding: 12px 16px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.03);
  color: #f1f5f9;
  font-size: 14px;
  font-family: inherit;
  transition: all 0.2s ease;
}

.hostAddStayForm input:focus,
.hostAddStayForm textarea:focus {
  border-color: rgba(16,185,129,0.5);
  background: rgba(16,185,129,0.05);
  box-shadow: 0 0 0 3px rgba(16,185,129,0.1);
  outline: none;
}

.hostAddStayForm textarea {
  min-height: 100px;
  resize: vertical;
}

.hostAddStayForm button {
  margin-top: 8px;
  margin-right: 10px;
}

/* ── Footer ──────────────────────────────────────────── */
.profileDashFooter {
  margin-top: auto;
  padding: 24px 32px;
  border-top: 1px solid rgba(255,255,255,0.05);
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 24px;
  color: rgba(148,163,184,0.6);
  font-size: 13px;
}

.profileDashFooterBrand {
  font-weight: 600;
}

.profileDashFooterLinks {
  display: flex;
  justify-content: center;
  gap: 24px;
}

.profileDashFooterLinks a {
  color: rgba(148,163,184,0.7);
  text-decoration: none;
  transition: color 0.2s ease;
}

.profileDashFooterLinks a:hover {
  color: #e2e8f0;
}

.profileDashFooterCredit {
  display: flex;
  align-items: center;
  gap: 6px;
}

.profileDashFooterCreditLink {
  background: linear-gradient(135deg, #10b981, #34d399);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 700;
  text-decoration: none;
}

/* ═══════════════════════════════════════════════════════
   RESPONSIVE DESIGN
   ═══════════════════════════════════════════════════════ */

@media (max-width: 1200px) {
  .profileDashLayout {
    grid-template-columns: 260px minmax(0, 1fr);
    gap: 24px;
    padding: 24px;
  }
  
  .hostDashStatsGrid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 1024px) {
  .profileDashLayout {
    grid-template-columns: 1fr;
  }
  
  .profileDashSidebar {
    position: relative;
    top: 0;
    display: none;
  }
  
  .profileDashSidebar.open {
    display: flex;
    animation: sidebarSlideMobile 0.4s ease;
  }
  
  .profileDashSidebar.closed {
    display: none;
  }
  
  @keyframes sidebarSlideMobile {
    from { opacity: 0; transform: translateX(-20px); }
    to { opacity: 1; transform: translateX(0); }
  }
  
  .sidebarToggleBtn {
    display: flex;
    position: fixed;
    left: 20px;
    top: 90px;
    z-index: 100;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(15, 23, 42, 0.8);
    backdrop-filter: blur(10px);
    color: #e2e8f0;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }
  
  .sidebarToggleBtn:hover {
    background: rgba(255,255,255,0.1);
    transform: scale(1.05);
  }
  
  .sidebarToggleIcon {
    font-size: 12px;
    transition: transform 0.3s ease;
  }
  
  .searchBar {
    grid-template-columns: 1fr;
    gap: 12px;
    padding: 16px;
  }
  
  .searchDivider {
    display: none;
  }
  
  .searchField {
    padding: 8px 0;
  }
  
  .searchButton {
    width: 100%;
    min-height: 48px;
    border-radius: 12px;
  }
  
  .heroTitle {
    font-size: clamp(32px, 8vw, 48px);
  }
  
  .heroSubtitle {
    font-size: clamp(14px, 4vw, 18px);
  }
  
  .navbar {
    padding: 16px 24px;
  }
  
  .navLinks {
    display: none;
  }
  
  .mobileMenuToggle {
    display: flex;
  }
  
  .mobileNavPanel {
    display: block;
    position: fixed;
    top: 80px;
    left: 0;
    right: 0;
    background: rgba(10, 10, 10, 0.98);
    backdrop-filter: blur(20px);
    padding: 20px;
    z-index: 999;
    transform: translateY(-100%);
    opacity: 0;
    transition: all 0.3s ease;
    pointer-events: none;
  }
  
  .mobileNavPanel.open {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
  
  .mobileNavPanel .navLink {
    display: block;
    padding: 14px 0;
    font-size: 16px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  
  .availabilityModalLayout {
    grid-template-columns: 1fr;
  }
  
  .availabilityModalMain {
    min-height: auto;
  }
  
  .profileDashTripCard {
    grid-template-columns: 1fr;
    height: auto;
  }
  
  .profileDashTripCard img {
    height: 180px;
  }
  
  .hostDashStatsGrid {
    grid-template-columns: 1fr;
  }
  
  .hostDashKpiGrid {
    grid-template-columns: 1fr;
  }
  
  .profileDashFavoritesGrid {
    grid-template-columns: 1fr;
  }
  
  .listingsGrid.improvedGrid {
    grid-template-columns: 1fr;
  }
  
  .profileDashSettingList li {
    grid-template-columns: 1fr;
    gap: 12px;
  }
  
  .profileDashSettingList li:hover {
    margin: 0;
    padding-left: 0;
    padding-right: 0;
  }
  
  .profileDashSettingList input,
  .profileDashSettingList select,
  .profileDashInlineFields {
    max-width: 100%;
  }
  
  .profileDashPersonalHeader {
    flex-direction: column;
    gap: 20px;
  }
  
  .profileDashPersonalActions {
    width: 100%;
    justify-content: flex-start;
  }
  
  .hostDashReservationList li {
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
  
  .profileDashFooter {
    grid-template-columns: 1fr;
    text-align: center;
    gap: 16px;
  }
  
  .profileDashFooterLinks {
    flex-wrap: wrap;
  }
}

@media (max-width: 640px) {
  .hero {
    min-height: 600px;
  }
  
  .heroContent {
    padding: 0 20px;
    gap: 24px;
  }
  
  .searchBar {
    padding: 12px;
    border-radius: 16px;
  }
  
  .heroDatePickerCalendar.react-datepicker {
    border-radius: 16px;
  }
  
  .heroDatePickerCalendar .react-datepicker__month-container {
    width: 280px;
  }
  
  .availabilityModalCard {
    border-radius: 20px;
    padding: 24px 20px;
  }
  
  .availabilityShowBtn {
    width: 100%;
  }
  
  .profileDashLayout {
    padding: 16px;
  }
  
  .profileDashHeading h1 {
    font-size: 24px;
  }
  
  .profileDashPersonalCard {
    padding: 20px;
  }
  
  .hostDashPanel {
    padding: 20px;
  }
  
  .hostAddStayForm {
    padding: 24px 20px;
  }
}

/* Animations for page transitions */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fadeInUp {
  animation: fadeInUp 0.6s ease-out both;
}

/* Stagger delays */
.stagger-1 { animation-delay: 0.1s; }
.stagger-2 { animation-delay: 0.2s; }
.stagger-3 { animation-delay: 0.3s; }
.stagger-4 { animation-delay: 0.4s; }
.stagger-5 { animation-delay: 0.5s; }

/* Smooth scroll behavior */
html {
  scroll-behavior: smooth;
}

/* Custom scrollbar */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: rgba(255,255,255,0.02);
}

::-webkit-scrollbar-thumb {
  background: rgba(255,255,255,0.1);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(255,255,255,0.15);
}

/* Focus styles for accessibility */
button:focus-visible,
a:focus-visible,
input:focus-visible,
select:focus-visible,
textarea:focus-visible {
  outline: 2px solid rgba(16,185,129,0.5);
  outline-offset: 2px;
}

/* Selection color */
::selection {
  background: rgba(16,185,129,0.3);
  color: #ffffff;
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}
